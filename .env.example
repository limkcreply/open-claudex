# open-claudex configuration
# Copy to .env and edit for your setup

# ─── Required ─────────────────────────────────────────────────────────────────
CLAUDE_CODE_USE_LOCAL=1

# ─── Local LLM Server ────────────────────────────────────────────────────────
# Your OpenAI-compatible server URL (pick one):
CLAUDEX_SERVER_URL=http://localhost:8080
# CLAUDE_CODE_LOCAL_ENDPOINT=http://localhost:8080

# Model name (auto-detected from server if not set)
# ANTHROPIC_MODEL=gemma-4-26B-A4B-it
# ANTHROPIC_MODEL=llama-3.1-70b
# ANTHROPIC_MODEL=qwen3-coder:30b
# ANTHROPIC_MODEL=mistral-large

# API key (most local servers ignore this)
ANTHROPIC_API_KEY=local-llm-key

# ─── Server Examples ─────────────────────────────────────────────────────────
# llama.cpp:     CLAUDEX_SERVER_URL=http://localhost:8080
# Ollama:        CLAUDEX_SERVER_URL=http://localhost:11434
# vLLM:          CLAUDEX_SERVER_URL=http://localhost:8000
# LiteLLM:       CLAUDEX_SERVER_URL=http://localhost:4000
# text-gen-webui: CLAUDEX_SERVER_URL=http://localhost:5000

# ─── Optional ────────────────────────────────────────────────────────────────
# Timeout for API calls (ms, default 600000 = 10 min)
# API_TIMEOUT_MS=600000

# Isolated config directory (won't touch your real ~/.claude)
# CLAUDE_CONFIG_DIR=$HOME/.claudex
